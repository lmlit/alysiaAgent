# OpenAI-compatible API configuration
# Copy this file to .env and fill in your values

# Base URL — change this to switch providers:
#   OpenAI:     https://api.openai.com/v1
#   DeepSeek:   https://api.deepseek.com/v1  (LLM only, no embeddings)
#   Moonshot:   https://api.moonshot.cn/v1
#   Zhipu:      https://open.bigmodel.cn/api/paas/v4
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=your-api-key-here

# Embedding model (OpenAI-compatible /v1/embeddings endpoint)
# NOTE: DeepSeek does NOT support embeddings. Use OpenAI or another provider.
#   OpenAI:  text-embedding-3-small (1536 dims)
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSION=1536

# Chat model (OpenAI-compatible /v1/chat/completions endpoint)
#   OpenAI: gpt-4o-mini
#   DeepSeek: deepseek-chat
CHAT_MODEL=deepseek-chat
